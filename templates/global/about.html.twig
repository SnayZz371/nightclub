{% extends 'base.html.twig' %}

{% block title %}Hello GlobalController!{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Historique</h2>
        <ul class="list-disc list-inside text-gray-700 dark:text-gray-300">
            {% for année, description in historique %}
                <li class="mb-2"><strong class="text-gray-900 dark:text-white">{{ année }}</strong> : {{ description }}</li>
            {% else %}
                <li class="text-gray-500 dark:text-gray-400">Aucun événement historique disponible.</li>
            {% endfor %}
        </ul>
    </div>
{% endblock %}
