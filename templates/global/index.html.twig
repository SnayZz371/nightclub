{% extends 'base.html.twig' %}

{% block title %}Hello GlobalController!{% endblock %}

{% block body %}
    <div class="container mx-auto  py-8 text-center">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Welcome {{ title | upper }}! ✅</h1>

        <p class="dark:text-gray-300 mb-4">This friendly message is coming from:</p>
        <img class="scale-50 " src="{{ asset('image/soiree.avif') }}" alt="">
    </div>
    <div>
            <h2>liste des prochaines soirées</h2>
            <ul>    
                {% for soiree in liste_soirees %}
                    <li>
                        <a href="{{ path('app_soiree_show', {'id': soiree.id}) }}" class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 transition-colors duration-200">
                            {{ soiree.titre }} - {{ soiree.dateSoiree ? soiree.dateSoiree|date('d/m/Y H:i') : '' }}
                        </a>
                    </li>
                {% else %}
                    <li class="text-gray-500 dark:text-gray-400">Aucune soirée à venir trouvée</li>
                {% endfor %}
            </ul>
        </div>
{% endblock %}
