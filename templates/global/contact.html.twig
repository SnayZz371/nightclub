
{% extends 'base.html.twig' %}
{% form_theme form 'tailwind_2_layout.html.twig' %}

{% block title %}Contact{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Nous Contacter</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Formulaire de Contact</h2>
            {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}
            {{ form_widget (form) }}
            <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded transition-colors duration-200">
                Envoyer
            </button>
            {{ form_end(form) }}
        </div>

        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 overflow-hidden rounded-lg">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Localisation</h2>
            <div style="height: 400px; border-radius: 8px; overflow: hidden;">
                {{ ux_map(map, {style: 'height: 100%; width: 100%'}) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}