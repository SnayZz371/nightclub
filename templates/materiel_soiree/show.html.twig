{% extends 'base.html.twig' %}

{% block title %}Matériel Soirée{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Matériel Soirée</h1>

        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <table class="min-w-full table-auto text-sm text-left text-gray-500 dark:text-gray-400">
                <tbody class="bg-white divide-y divide-gray-200 dark:bg-gray-800 dark:divide-gray-700">
                    <tr>
                        <th class="px-6 py-4 font-medium text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700">ID</th>
                        <td class="px-6 py-4">{{ materiel_soiree.id }}</td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 font-medium text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700">Date de Réservation Début</th>
                        <td class="px-6 py-4">{{ materiel_soiree.dateReservationDebut ? materiel_soiree.dateReservationDebut|date('d/m/Y') : 'Non disponible' }}</td>
                    </tr>
                    <tr>
                        <th class="px-6 py-4 font-medium text-gray-900 dark:text-white bg-gray-50 dark:bg-gray-700">Date de Réservation Fin</th>
                        <td class="px-6 py-4">{{ materiel_soiree.dateReservationFin ? materiel_soiree.dateReservationFin|date('d/m/Y') : 'Non disponible' }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="mt-6 flex gap-4">
            <a href="{{ path('app_materiel_soiree_index') }}" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded transition-colors duration-200">Retour à la liste</a>
            <a href="{{ path('app_materiel_soiree_edit', {'id': materiel_soiree.id}) }}" class="bg-yellow-500 hover:bg-yellow-600 text-white font-bold py-2 px-4 rounded transition-colors duration-200">Éditer</a>
        </div>

        {{ include('materiel_soiree/_delete_form.html.twig') }}
    </div>
{% endblock %}
