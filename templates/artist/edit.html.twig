{% extends 'base.html.twig' %}

{% block title %}Edit Artist{% endblock %}

{% block body %}
    <div class="container mx-auto px-4 py-8">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">Éditer l'artiste</h1>

        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg p-6 mb-6">
            {{ include('artist/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>

        <div class="flex gap-4">
            <a href="{{ path('app_artist_index') }}" class="bg-gray-500 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded transition-colors duration-200">Retour à la liste</a>
        </div>

        <div class="mt-6">
            {{ include('artist/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
